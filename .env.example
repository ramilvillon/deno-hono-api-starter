PORT=3000
LOG_LEVEL=debug
# Host port Docker binds MySQL to (docker-compose). Override if 3306 is taken;
# keep it in sync with the port in DATABASE_URL.
MYSQL_PORT=3306
DATABASE_URL=mysql://app:app@localhost:3306/app
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Set true ONLY when behind a trusted reverse proxy (then X-Forwarded-For is honored)
TRUST_PROXY=false
# REDIS_URL=redis://localhost:6379
# REDIS_PORT=6379   # host port Docker binds Redis to (compose --profile redis)
